# Node dependencies
backend/node_modules/
frontend/node_modules/

# Secrets
backend/.env
**/.env
!**/.env.example

# Frontend build outputs
frontend/dist/
frontend/build/

# Backend generated data: ignore everything except .gitkeep
backend/database/*
!backend/database/.gitkeep
backend/reports/*
!backend/reports/.gitkeep

# Scan output directories (can grow into many GB)
results/

# Compressed scan artefacts
*.gz
*.zip
*.tar
*.tgz

# OS / IDE noise
.DS_Store
Thumbs.db
*.swp
.idea/

# Logs
*.log
