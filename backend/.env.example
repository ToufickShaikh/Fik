# Fik backend environment overrides — copy to backend/.env to activate.
# All values are optional; the framework runs fine with everything unset.

# --- Notifications (notify.sh) -----------------------------------------------
# NOTIFY_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# NOTIFY_WEBHOOK_TYPE=slack       # slack | discord | telegram | generic

# --- AI report writer (report_generator.js) ----------------------------------
# GEMINI_API_KEY=

# --- Outbound proxy ----------------------------------------------------------
# PROXY_URL=http://127.0.0.1:8080

# --- Recon tunables (see README §7) ------------------------------------------
# SCAN_PROFILE=standard
# MAX_WAYBACK_URLS=50000
# MAX_ENDPOINTS=50000
# MAX_ALL_URLS=100000
# RETENTION_KEEP=10
# COMPRESS_MIN_BYTES=65536
# KEEP_RAW_VULNS=1
# KEEP_RAW_WAYBACK=1
# SLIM_VULN_FIELDS=1
